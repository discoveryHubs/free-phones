---
import Layout from "../layouts/Layout.astro";

const SITE_URL = "https://free-phones.pages.dev";
const SITE_TITLE = "Free Government Phone Guide (2026)";
const SITE_DESCRIPTION =
  "Fast, practical Lifeline guide: eligibility, documents, provider selection, and scam-safe steps to apply for a free or discounted phone.";
---

<Layout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  canonicalURL={SITE_URL + "/"}
>
  <main class="mx-auto max-w-6xl px-4 pb-16">
    <!-- HERO -->
    <section class="pt-10 md:pt-14">
      <div class="rounded-2xl border border-slate-200 bg-white/60 p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900/40 md:p-10">
        <div class="grid gap-8 md:grid-cols-2 md:items-center">
          <div>
            <p class="inline-flex items-center rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-semibold text-slate-700 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-200">
              Updated 2026 • Lifeline focused • Scam-safe checklist
            </p>

            <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100 md:text-5xl">
              Free Government Phone Guide
            </h1>

            <p class="mt-4 text-base leading-relaxed text-slate-600 dark:text-slate-300 md:text-lg">
              A trust-first, plain-language guide to the Lifeline phone benefit. Learn who may qualify, what documents you need,
              and how to apply safely through legitimate providers.
            </p>

            <div class="mt-6 flex flex-wrap gap-3">
              <a
                href="/posts/"
                class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:opacity-95 dark:bg-slate-100 dark:text-slate-900"
              >
                Read Latest Guides
              </a>

              <a
                href="#eligibility"
                class="inline-flex items-center justify-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-900"
              >
                Eligibility Basics
              </a>
            </div>

            <div class="mt-6 grid gap-3 sm:grid-cols-3">
              <div class="rounded-xl border border-slate-200 p-4 dark:border-slate-800">
                <div class="text-sm font-semibold text-slate-900 dark:text-slate-100">Clarity</div>
                <div class="mt-1 text-xs text-slate-600 dark:text-slate-300">Simple steps, no confusion</div>
              </div>
              <div class="rounded-xl border border-slate-200 p-4 dark:border-slate-800">
                <div class="text-sm font-semibold text-slate-900 dark:text-slate-100">E-E-A-T</div>
                <div class="mt-1 text-xs text-slate-600 dark:text-slate-300">Trust-first information design</div>
              </div>
              <div class="rounded-xl border border-slate-200 p-4 dark:border-slate-800">
                <div class="text-sm font-semibold text-slate-900 dark:text-slate-100">Speed</div>
                <div class="mt-1 text-xs text-slate-600 dark:text-slate-300">Static build, fast loading</div>
              </div>
            </div>
          </div>

          <!-- TRUST PANEL -->
          <aside class="rounded-2xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white p-6 dark:border-slate-800 dark:from-slate-900 dark:to-slate-950">
            <h2 class="text-lg font-bold text-slate-900 dark:text-slate-100">
              Transparency (important)
            </h2>
            <ul class="mt-4 space-y-3 text-sm text-slate-700 dark:text-slate-200">
              <li class="flex gap-2">
                <span class="mt-1 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                This is an informational website, not a government agency.
              </li>
              <li class="flex gap-2">
                <span class="mt-1 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                Device offers depend on provider inventory and eligibility verification.
              </li>
              <li class="flex gap-2">
                <span class="mt-1 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                We do not guarantee specific phone models.
              </li>
            </ul>

            <div class="mt-6 rounded-xl border border-slate-200 bg-white p-4 dark:border-slate-800 dark:bg-slate-950">
              <div class="text-xs font-semibold uppercase tracking-wide text-slate-600 dark:text-slate-300">
                Editorial promise
              </div>
              <p class="mt-2 text-sm leading-relaxed text-slate-700 dark:text-slate-200">
                Guides are written to be clear and updated when provider processes change. If something is outdated, we correct it.
              </p>
            </div>

            <div class="mt-6">
              <a
                href="/about/"
                class="inline-flex w-full items-center justify-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-900"
              >
                About this site
              </a>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- ELIGIBILITY -->
    <section id="eligibility" class="mt-12 scroll-mt-24">
      <div class="rounded-2xl border border-slate-200 p-6 dark:border-slate-800 md:p-10">
        <h2 class="text-2xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100">
          Who may qualify for a free or discounted phone
        </h2>
        <p class="mt-3 max-w-3xl text-slate-600 dark:text-slate-300">
          Eligibility is usually based on household income or participation in qualifying assistance programs. Requirements can vary by verification path.
        </p>

        <div class="mt-6 grid gap-6 md:grid-cols-2">
          <div class="rounded-2xl border border-slate-200 p-6 dark:border-slate-800">
            <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100">Common eligibility paths</h3>
            <ul class="mt-4 space-y-2 text-sm text-slate-700 dark:text-slate-200">
              <li class="flex gap-2">
                <span class="mt-1 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                Income-based qualification (household income threshold)
              </li>
              <li class="flex gap-2">
                <span class="mt-1 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                Program-based qualification (participation proof)
              </li>
              <li class="flex gap-2">
                <span class="mt-1 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                Tribal enhancements may be available in eligible areas
              </li>
            </ul>
          </div>

          <div class="rounded-2xl border border-slate-200 p-6 dark:border-slate-800">
            <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100">Documents to prepare</h3>
            <ul class="mt-4 space-y-2 text-sm text-slate-700 dark:text-slate-200">
              <li class="flex gap-2">
                <span class="mt-1 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                Government-issued ID (matching name and date of birth)
              </li>
              <li class="flex gap-2">
                <span class="mt-1 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                Proof of eligibility (income docs or program participation)
              </li>
              <li class="flex gap-2">
                <span class="mt-1 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                Proof of address (if required)
              </li>
            </ul>
          </div>
        </div>

        <div class="mt-6 rounded-2xl border border-slate-200 bg-slate-50 p-6 dark:border-slate-800 dark:bg-slate-900/40">
          <p class="text-sm text-slate-700 dark:text-slate-200">
            Important: Lifeline is typically one benefit per household. Approval depends on verification rules and provider processes.
          </p>
        </div>
      </div>
    </section>

    <!-- SAFETY -->
    <section class="mt-12">
      <div class="rounded-2xl border border-slate-200 p-6 dark:border-slate-800 md:p-10">
        <h2 class="text-2xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100">
          Scam-safe checklist
        </h2>
        <p class="mt-3 max-w-3xl text-slate-600 dark:text-slate-300">
          If a site promises guaranteed premium devices without verification, treat it as a red flag. Use these signals to stay safe.
        </p>

        <div class="mt-6 grid gap-6 md:grid-cols-2">
          <div class="rounded-2xl border border-slate-200 p-6 dark:border-slate-800">
            <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100">Red flags</h3>
            <ul class="mt-4 space-y-2 text-sm text-slate-700 dark:text-slate-200">
              <li class="flex gap-2"><span class="mt-1 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>Guaranteed iPhone claims without eligibility checks</li>
              <li class="flex gap-2"><span class="mt-1 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>Unusual upfront fees or pressure tactics</li>
              <li class="flex gap-2"><span class="mt-1 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>No clear company identity or support details</li>
            </ul>
          </div>

          <div class="rounded-2xl border border-slate-200 p-6 dark:border-slate-800">
            <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100">Safe steps</h3>
            <ul class="mt-4 space-y-2 text-sm text-slate-700 dark:text-slate-200">
              <li class="flex gap-2"><span class="mt-1 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>Apply through legitimate providers and follow verification steps</li>
              <li class="flex gap-2"><span class="mt-1 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>Ensure your details match your documents</li>
              <li class="flex gap-2"><span class="mt-1 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>Keep confirmations and screenshots for your records</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="mt-12">
      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6 dark:border-slate-800 dark:bg-slate-900/40 md:p-10">
        <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
          <div>
            <h2 class="text-xl font-extrabold text-slate-900 dark:text-slate-100">
              Start with the latest guides
            </h2>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
              Browse step-by-step posts and provider explainers.
            </p>
          </div>
          <div class="flex gap-3">
            <a
              href="/posts/"
              class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:opacity-95 dark:bg-slate-100 dark:text-slate-900"
            >
              View Posts
            </a>
            <a
              href="/search/"
              class="inline-flex items-center justify-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-900"
            >
              Search
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script is:inline type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: SITE_TITLE,
      url: SITE_URL,
      description: SITE_DESCRIPTION,
      inLanguage: "en"
    })}
  </script>

  <script is:inline type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "Is the free government phone benefit real?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Yes. Lifeline is a real federal benefit that helps eligible households reduce the cost of phone service. Device availability depends on participating providers and inventory."
          }
        },
        {
          "@type": "Question",
          name: "What do I need to apply?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Typically you need proof of identity and proof of eligibility, such as program participation or income documentation, plus an address where service will be used."
          }
        },
        {
          "@type": "Question",
          name: "Can I get more than one Lifeline phone per household?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Usually no. Lifeline is generally limited to one benefit per household."
          }
        }
      ]
    })}
  </script>
</Layout>
