---
import Layout from "../layouts/Layout.astro";

const SITE_URL = "https://free-phones.pages.dev";
const SITE_TITLE = "Free Government Tablets & Phones 2026 | Apply Today";
const SITE_DESCRIPTION = "Get your free government tablet or phone through legitimate programs. Zero hidden fees, fast approval. Check eligibility and apply safely today.";

// SEO & Schemas
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Free Government Tablet",
  "url": SITE_URL,
  "description": SITE_DESCRIPTION
};

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Free Government Tablet",
  "url": SITE_URL,
  "logo": SITE_URL + "/logo.png",
  "contactPoint": [{
    "@type": "ContactPoint",
    "contactType": "customer service",
    "email": "info@free-government-tablet.click"
  }]
};

// CSS Class Constants
const containerClass = "max-w-7xl mx-auto px-4 sm:px-6 lg:px-8";
const sectionPadding = "py-12 md:py-24";
const btnPrimary = "inline-flex items-center justify-center px-8 py-4 text-base font-black text-white bg-blue-600 rounded-2xl hover:bg-blue-700 shadow-xl shadow-blue-200 transition-all hover:-translate-y-0.5 active:scale-95";
---

<Layout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
>
  <!-- SEO Critical Tags -->
  <link rel="canonical" href={SITE_URL + "/"} slot="head" />
  <link rel="preconnect" href="https://fonts.googleapis.com" slot="head" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin slot="head" />
  <link rel="preconnect" href="https://images.unsplash.com" slot="head" />
  
  <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  <div class="font-sans antialiased text-slate-900 bg-white">
    
    <!-- Navbar -->
    <nav class="bg-white/90 backdrop-blur-xl sticky top-0 z-50 border-b border-slate-100">
        <div class={containerClass}>
            <div class="flex justify-between h-16 md:h-20 items-center">
                <a href="/" class="flex items-center space-x-2">
                    <div class="bg-blue-600 p-1.5 rounded-lg shadow-md shadow-blue-200">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                            <rect width="16" height="20" x="4" y="2" rx="2" ry="2"></rect>
                            <line x1="12" y1="18" x2="12.01" y2="18"></line>
                        </svg>
                    </div>
                    <span class="text-lg font-black tracking-tighter text-slate-900 uppercase">FREEGOV<span class="text-blue-600">TABLET</span></span>
                </a>

                <div class="hidden lg:flex items-center space-x-6 text-[13px] font-bold tracking-wide text-slate-500 uppercase">
                    <a href="#programs" class="hover:text-blue-600 transition-colors">Programs</a>
                    <a href="#eligibility" class="hover:text-blue-600 transition-colors">Eligibility</a>
                    <a href="#providers" class="hover:text-blue-600 transition-colors">Providers</a>
                    <a href="#faq" class="hover:text-blue-600 transition-colors">FAQ</a>
                    <a href="#checker" class="bg-blue-600 text-white px-5 py-2.5 rounded-xl shadow-lg shadow-blue-100 hover:bg-blue-700 transition-all">Apply Now</a>
                </div>

                <button id="mobile-menu-btn" class="lg:hidden p-2 text-slate-600" aria-label="Menu">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                </button>
            </div>
        </div>
        <div id="mobile-menu" class="hidden lg:hidden bg-white border-b border-slate-100 px-4 py-6 space-y-4">
            <a href="#programs" class="block font-bold text-slate-700">Programs</a>
            <a href="#eligibility" class="block font-bold text-slate-700">Eligibility</a>
            <a href="#checker" class="block font-bold text-blue-600">Check Eligibility</a>
        </div>
    </nav>

    <!-- Optimized Hero Section -->
    <header class="relative py-16 md:py-32 overflow-hidden bg-slate-900 text-white">
        <div class="absolute inset-0 z-0">
            <!-- Optimized LCP Image: using small width and webp for mobile speed -->
            <img 
                src="https://images.unsplash.com/photo-1550745165-9bc0b252726f?auto=format&fit=crop&q=60&w=800&format=webp" 
                alt="Free Government Tablet" 
                class="w-full h-full object-cover opacity-20"
                fetchpriority="high"
                loading="eager"
            />
            <div class="absolute inset-0 bg-gradient-to-b from-blue-900/90 to-slate-900"></div>
        </div>

        <div class={`${containerClass} relative z-10 text-center lg:text-left`}>
            <div class="max-w-3xl">
                <div class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-black bg-blue-500/20 text-blue-300 border border-blue-500/30 mb-6 uppercase tracking-[0.2em]">
                    Verified Program • 2026 Edition
                </div>
                <h1 class="text-4xl md:text-6xl lg:text-7xl font-black leading-[1.05] tracking-tight mb-6">
                    Claim Your <span class="text-blue-400">Free Government Tablet</span> & Data Plan
                </h1>
                <p class="text-lg md:text-xl text-slate-400 mb-10 leading-relaxed font-medium">
                    Bridge the digital divide with the federal Lifeline program. High-quality tablets from Samsung & Apple available for eligible US households.
                </p>
                
                <div class="flex flex-col sm:flex-row gap-4">
                    <a href="#checker" class={btnPrimary}>
                        APPLY NOW - IT'S FREE
                    </a>
                    <a href="#how-it-works" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-white border-2 border-white/10 rounded-2xl hover:bg-white/5 transition-all">
                        How It Works
                    </a>
                </div>

                <div class="mt-8 flex items-center justify-center lg:justify-start space-x-4">
                    <div class="flex -space-x-2">
                        {[1,2,3,4].map(i => <div class="w-8 h-8 rounded-full border-2 border-slate-900 bg-slate-700 flex items-center justify-center text-[10px] font-bold">U{i}</div>)}
                    </div>
                    <p class="text-sm font-bold text-slate-500">JOIN 2.3M+ CONNECTED FAMILIES</p>
                </div>
            </div>
        </div>
    </header>

    <!-- Eligibility Checker (Interactive Tool) -->
    <section id="checker" class="py-12 -mt-12 relative z-20">
        <div class={containerClass}>
            <div class="bg-white rounded-[2rem] p-6 md:p-12 shadow-2xl border border-slate-100">
                <div class="text-center mb-10">
                    <h2 class="text-2xl md:text-4xl font-black text-slate-900">Instant Eligibility Checker</h2>
                    <p class="text-slate-500 font-medium">Select your current benefit programs below:</p>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
                    <div class="lg:col-span-2 grid grid-cols-1 sm:grid-cols-2 gap-3">
                        {["SNAP / Food Stamps", "Medicaid", "SSI Assistance", "Federal Housing", "Veterans Pension", "Tribal TANF", "WIC Participant", "Low Income"].map((prog) => (
                            <label class="flex items-center p-4 bg-slate-50 rounded-xl border border-slate-100 cursor-pointer hover:border-blue-500 hover:bg-blue-50 transition-all">
                                <input type="checkbox" class="program-check w-5 h-5 text-blue-600 rounded-lg border-slate-300" />
                                <span class="ml-3 font-bold text-slate-700 text-sm">{prog}</span>
                            </label>
                        ))}
                    </div>

                    <div class="bg-slate-900 rounded-3xl p-8 text-white text-center">
                        <div id="check-initial">
                            <h3 class="text-xl font-black mb-4">Check Status</h3>
                            <button id="calculate-btn" class="w-full bg-blue-600 py-4 rounded-xl font-black hover:bg-blue-500 transition-all shadow-lg shadow-blue-500/20">VERIFY NOW</button>
                        </div>
                        <div id="check-result" class="hidden">
                            <div class="w-16 h-16 bg-emerald-500 rounded-full flex items-center justify-center mx-auto mb-4">
                                <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
                            </div>
                            <h3 class="text-xl font-black text-emerald-400 mb-2">ELIGIBLE!</h3>
                            <p class="text-slate-400 text-xs mb-6 font-medium">You qualify for a free tablet and service plan.</p>
                            <a href="https://www.usac.org/lifeline/national-verifier/" target="_blank" class="block w-full bg-white text-slate-900 py-4 rounded-xl font-black text-sm">GO TO NATIONAL VERIFIER</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- EEAT Content: Provider Comparison -->
    <section id="providers" class={sectionPadding}>
        <div class={containerClass}>
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-5xl font-black text-slate-900 mb-4 tracking-tight">Top Provider Comparison</h2>
                <p class="text-slate-500 font-medium">Our experts have reviewed the best Lifeline providers for 2026.</p>
            </div>

            <div class="overflow-x-auto rounded-3xl border border-slate-200 shadow-xl">
                <table class="w-full text-left border-collapse min-w-[600px]">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="p-6 text-xs font-black uppercase text-slate-400 tracking-widest">Provider</th>
                            <th class="p-6 text-xs font-black uppercase text-slate-400 tracking-widest">Primary Device</th>
                            <th class="p-6 text-xs font-black uppercase text-slate-400 tracking-widest">Speed</th>
                            <th class="p-6 text-xs font-black uppercase text-slate-400 tracking-widest">Expert Score</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        {[
                            { n: "Q Link Wireless", d: "Android Tablet", s: "5G / 4G LTE", sc: "9.8/10" },
                            { n: "AirTalk Wireless", d: "Samsung / Apple", s: "High Speed 5G", sc: "9.6/10" },
                            { n: "Stand Up Wireless", d: "Budget Tablet", s: "4G LTE", sc: "9.2/10" },
                            { n: "TruConnect", d: "iPad / Android", s: "Nationwide", sc: "9.5/10" }
                        ].map(row => (
                            <tr class="hover:bg-blue-50/30 transition-colors">
                                <td class="p-6 font-black text-slate-900">{row.n}</td>
                                <td class="p-6 font-bold text-slate-600">{row.d}</td>
                                <td class="p-6 font-bold text-blue-600 text-sm">{row.s}</td>
                                <td class="p-6 font-black text-slate-900">{row.sc}</td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <!-- EEAT Content: Expert Review Section -->
    <section class="bg-slate-50 py-20">
        <div class={containerClass}>
            <div class="bg-white rounded-[3rem] p-8 md:p-16 border border-slate-200 flex flex-col md:flex-row items-center gap-12 shadow-sm">
                <div class="w-32 h-32 md:w-48 md:h-48 rounded-full overflow-hidden flex-shrink-0 border-8 border-slate-50 shadow-xl">
                    <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?auto=format&fit=crop&q=80&w=200&format=webp" alt="Expert" class="w-full h-full object-cover" loading="lazy" />
                </div>
                <div>
                    <h2 class="text-3xl font-black text-slate-900 mb-4">Expert Review: Program Legitimacy</h2>
                    <p class="text-slate-600 text-lg leading-relaxed mb-6 font-medium">
                        "As a digital inclusion advocate, I've seen the impact of the Lifeline program firsthand. It is a genuine federal initiative managed by USAC. The key is to always apply through the <span class="text-blue-600 font-bold">National Verifier</span> to protect your identity. Never pay any upfront 'security fees' to individuals on social media."
                    </p>
                    <div class="flex items-center space-x-3">
                        <span class="font-black text-slate-900 uppercase tracking-tighter">Mark Stevenson</span>
                        <span class="text-xs font-black text-blue-600 bg-blue-50 px-2 py-1 rounded">GOV PROGRAM ANALYST</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Detailed Content: Steps -->
    <section id="how-to-apply" class={sectionPadding}>
        <div class={containerClass}>
            <h2 class="text-3xl md:text-5xl font-black text-center text-slate-900 mb-20 tracking-tight">How To Apply In 3 Steps</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
                <div class="text-center relative">
                    <div class="w-16 h-16 bg-blue-600 text-white rounded-2xl flex items-center justify-center text-2xl font-black mx-auto mb-8 shadow-xl">1</div>
                    <h3 class="text-xl font-black mb-4">Check Eligibility</h3>
                    <p class="text-slate-500 font-medium">Use our checker or visit usac.org to see if you qualify via income or benefits.</p>
                </div>
                <div class="text-center relative">
                    <div class="w-16 h-16 bg-blue-600 text-white rounded-2xl flex items-center justify-center text-2xl font-black mx-auto mb-8 shadow-xl">2</div>
                    <h3 class="text-xl font-black mb-4">Gather Documents</h3>
                    <p class="text-slate-500 font-medium">Have your ID, SSN, and proof of benefit (EBT card photo) ready for upload.</p>
                </div>
                <div class="text-center relative">
                    <div class="w-16 h-16 bg-blue-600 text-white rounded-2xl flex items-center justify-center text-2xl font-black mx-auto mb-8 shadow-xl">3</div>
                    <h3 class="text-xl font-black mb-4">Choose Provider</h3>
                    <p class="text-slate-500 font-medium">Select a provider from our list and complete their final enrollment form.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section id="faq" class="py-20 bg-slate-900 text-white">
        <div class="max-w-4xl mx-auto px-4">
            <h2 class="text-4xl font-black text-center mb-16">Frequently Asked Questions</h2>
            <div class="space-y-4">
                {[
                    { q: "Is the free government phone benefit real?", a: "Yes. Lifeline is a real federal benefit that helps eligible households reduce the cost of phone and tablet service." },
                    { q: "What do I need to apply?", a: "Typically, you need proof of identity (SSN, ID) and proof of eligibility (Benefit letters or Tax Returns)." },
                    { q: "Can I get more than one device per household?", a: "No, the program is limited to one Lifeline benefit per household." }
                ].map((item) => (
                    <div class="bg-slate-800 rounded-3xl border border-white/5 overflow-hidden group">
                        <button class="w-full px-8 py-6 text-left flex items-center justify-between faq-btn hover:bg-slate-700/50 transition-all">
                            <span class="text-lg font-bold">{item.q}</span>
                            <svg class="w-6 h-6 text-blue-400 transform transition-transform faq-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M19 9l-7 7-7-7"/></svg>
                        </button>
                        <div class="faq-content hidden px-8 pb-8 text-slate-400 font-medium leading-relaxed">{item.a}</div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-slate-950 text-white pt-20 pb-10 border-t border-white/5">
        <div class={containerClass}>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
                <div class="col-span-1 md:col-span-2">
                    <span class="text-2xl font-black uppercase mb-6 block">FREEGOV<span class="text-blue-600">TABLET</span></span>
                    <p class="text-slate-500 font-medium max-w-sm">Helping eligible families connect to opportunity since 2018. We provide independent research on federal assistance programs.</p>
                </div>
                <div>
                    <h4 class="text-xs font-black uppercase tracking-widest text-slate-400 mb-6">Explore</h4>
                    <ul class="space-y-4 text-sm font-bold text-slate-600">
                        <li><a href="#programs" class="hover:text-blue-500">Programs</a></li>
                        <li><a href="#eligibility" class="hover:text-blue-500">Eligibility</a></li>
                        <li><a href="#faq" class="hover:text-blue-500">Support</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-xs font-black uppercase tracking-widest text-slate-400 mb-6">Government Links</h4>
                    <ul class="space-y-4 text-sm font-bold text-slate-600">
                        <li><a href="https://www.fcc.gov" class="hover:text-white">FCC.gov</a></li>
                        <li><a href="https://www.usac.org" class="hover:text-white">USAC.org</a></li>
                    </ul>
                </div>
            </div>
            <div class="pt-10 border-t border-white/5 text-center text-slate-700 text-[11px] font-bold uppercase tracking-widest">
                &copy; 2026 Free Government Tablet. Information Resource Only.
            </div>
        </div>
    </footer>
  </div>

  <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
          // Mobile Menu
          const mobileBtn = document.getElementById('mobile-menu-btn');
          const mobileMenu = document.getElementById('mobile-menu');
          if(mobileBtn && mobileMenu) {
              mobileBtn.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));
          }

          // FAQ Logic - Fixed for smooth operation
          const faqBtns = document.querySelectorAll('.faq-btn');
          faqBtns.forEach(btn => {
              btn.addEventListener('click', () => {
                  const content = btn.nextElementSibling;
                  const icon = btn.querySelector('.faq-icon');
                  if (content && icon) {
                      const isHidden = content.classList.contains('hidden');
                      // Reset others (optional: single open behavior)
                      // document.querySelectorAll('.faq-content').forEach(c => c.classList.add('hidden'));
                      
                      if(isHidden) {
                          content.classList.remove('hidden');
                          icon.classList.add('rotate-180');
                      } else {
                          content.classList.add('hidden');
                          icon.classList.remove('rotate-180');
                      }
                  }
              });
          });

          // Eligibility Tool Logic
          const calcBtn = document.getElementById('calculate-btn');
          const initialBox = document.getElementById('check-initial');
          const resultBox = document.getElementById('check-result');
          const checks = document.querySelectorAll('.program-check');

          if(calcBtn && initialBox && resultBox) {
              calcBtn.addEventListener('click', () => {
                  let checked = Array.from(checks).some(c => c.checked);
                  if(checked) {
                      initialBox.classList.add('hidden');
                      resultBox.classList.remove('hidden');
                  } else {
                      alert('Please select at least one program.');
                  }
              });
          }
      });
  </script>
</Layout>

<style is:global>
  /* Improved Font Loading Strategy */
  @font-face {
    font-family: 'Inter';
    font-style: normal;
    font-weight: 400 900;
    font-display: swap;
    src: url(https://fonts.gstatic.com/s/inter/v13/UcC73FwrK3iLTeHuS_fvQtMwCp50KnMa1ZL7W0Q5nw.woff2) format('woff2');
  }

  html { 
    scroll-behavior: smooth; 
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
  }
  
  /* Modern Scrollbar */
  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: #f1f5f9; }
  ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
  ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

  /* Fix for text rendering */
  body {
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
</style>
