---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const SITE_TITLE = "Free Government Phone Guide";
const SITE_DESCRIPTION =
  "A fast, SEO-friendly guide to Lifeline phone benefits: eligibility, documents, providers, and safe application steps.";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href="https://free-phones.pages.dev/" />
    <meta property="og:title" content={SITE_TITLE} />
    <meta property="og:description" content={SITE_DESCRIPTION} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: SITE_TITLE,
        url: "https://free-phones.pages.dev/",
        description: SITE_DESCRIPTION,
        inLanguage: "en",
        publisher: {
          "@type": "Organization",
          name: SITE_TITLE
        }
      })}
    </script>

    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        name: SITE_TITLE,
        url: "https://free-phones.pages.dev/",
        sameAs: [],
        contactPoint: [
          {
            "@type": "ContactPoint",
            contactType: "customer support",
            email: "support@free-phones.pages.dev",
            availableLanguage: ["en"]
          }
        ]
      })}
    </script>

    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: [
          {
            "@type": "Question",
            name: "Is the free government phone benefit real?",
            acceptedAnswer: {
              "@type": "Answer",
              text: "Yes. Lifeline is a real federal benefit that helps eligible households reduce the cost of phone service. Device availability depends on participating providers and inventory."
            }
          },
          {
            "@type": "Question",
            name: "What do I need to apply?",
            acceptedAnswer: {
              "@type": "Answer",
              text: "Typically you need proof of identity and proof of eligibility, such as program participation or income documentation, plus an address where service will be used."
            }
          },
          {
            "@type": "Question",
            name: "Can I get more than one Lifeline phone per household?",
            acceptedAnswer: {
              "@type": "Answer",
              text: "Usually no. Lifeline is generally limited to one benefit per household, with limited exceptions in certain situations."
            }
          },
          {
            "@type": "Question",
            name: "How do I avoid scams?",
            acceptedAnswer: {
              "@type": "Answer",
              text: "Use official application pathways and reputable providers. Avoid sites that promise guaranteed premium phones with no verification, or ask for unusual fees and sensitive information."
            }
          }
        ]
      })}
    </script>
  </head>

  <body class="min-h-screen">
    <Header />

    <main class="mx-auto max-w-6xl px-4 pb-16">
      <!-- Hero -->
      <section class="pt-10 md:pt-14">
        <div class="rounded-2xl border border-slate-200 bg-white/60 p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900/40 md:p-10">
          <div class="grid gap-8 md:grid-cols-2 md:items-center">
            <div>
              <p class="inline-flex items-center rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-semibold text-slate-700 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-200">
                Updated 2026 • Lifeline focused • Fast, clean, and readable
              </p>

              <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100 md:text-5xl">
                Free Government Phone Guide
              </h1>

              <p class="mt-4 text-base leading-relaxed text-slate-600 dark:text-slate-300 md:text-lg">
                A practical, trust-first guide to the Lifeline phone benefit: who qualifies, what documents you need,
                how to apply safely, and how to choose a provider without wasting time.
              </p>

              <div class="mt-6 flex flex-wrap gap-3">
                <a
                  href="/posts/"
                  class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:opacity-95 dark:bg-slate-100 dark:text-slate-900"
                >
                  Read Latest Guides
                </a>
                <a
                  href="#eligibility"
                  class="inline-flex items-center justify-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-900"
                >
                  Check Eligibility Basics
                </a>
              </div>

              <div class="mt-6 grid gap-3 sm:grid-cols-3">
                <div class="rounded-xl border border-slate-200 p-4 dark:border-slate-800">
                  <div class="text-sm font-semibold text-slate-900 dark:text-slate-100">Clarity</div>
                  <div class="mt-1 text-xs text-slate-600 dark:text-slate-300">
                    Plain-language steps and examples
                  </div>
                </div>
                <div class="rounded-xl border border-slate-200 p-4 dark:border-slate-800">
                  <div class="text-sm font-semibold text-slate-900 dark:text-slate-100">Accuracy</div>
                  <div class="mt-1 text-xs text-slate-600 dark:text-slate-300">
                    Fact-checked, regularly updated
                  </div>
                </div>
                <div class="rounded-xl border border-slate-200 p-4 dark:border-slate-800">
                  <div class="text-sm font-semibold text-slate-900 dark:text-slate-100">Safety</div>
                  <div class="mt-1 text-xs text-slate-600 dark:text-slate-300">
                    Scam signals and safe-apply tips
                  </div>
                </div>
              </div>
            </div>

            <!-- Trust Card -->
            <div class="rounded-2xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white p-6 dark:border-slate-800 dark:from-slate-900 dark:to-slate-950">
              <h2 class="text-lg font-bold text-slate-900 dark:text-slate-100">
                What this site is, and what it is not
              </h2>
              <ul class="mt-4 space-y-3 text-sm text-slate-700 dark:text-slate-200">
                <li class="flex gap-2">
                  <span class="mt-0.5 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                  We explain the Lifeline benefit, eligibility paths, and provider selection in one place.
                </li>
                <li class="flex gap-2">
                  <span class="mt-0.5 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                  We do not claim to be the government. We do not guarantee a specific phone model.
                </li>
                <li class="flex gap-2">
                  <span class="mt-0.5 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                  Device offers depend on provider inventory, verification, and local availability.
                </li>
              </ul>

              <div class="mt-6 rounded-xl border border-slate-200 bg-white p-4 dark:border-slate-800 dark:bg-slate-950">
                <div class="text-xs font-semibold uppercase tracking-wide text-slate-600 dark:text-slate-300">
                  Editorial promise
                </div>
                <p class="mt-2 text-sm leading-relaxed text-slate-700 dark:text-slate-200">
                  Every guide is written for clarity, checked for consistency, and updated when rules or provider processes change.
                  If something looks outdated, we correct it.
                </p>
              </div>

              <div class="mt-6">
                <a
                  href="/about/"
                  class="inline-flex items-center justify-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-900"
                >
                  About this site
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- How it works -->
      <section class="mt-12">
        <h2 class="text-2xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100">
          How the free phone benefit usually works
        </h2>
        <p class="mt-3 max-w-3xl text-slate-600 dark:text-slate-300">
          Lifeline is primarily a monthly service discount. Some providers also include a device offer. Approval depends on verification.
        </p>

        <div class="mt-6 grid gap-4 md:grid-cols-3">
          <div class="rounded-2xl border border-slate-200 p-6 dark:border-slate-800">
            <div class="text-sm font-bold text-slate-900 dark:text-slate-100">1) Check eligibility</div>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
              You may qualify by income or by participating in certain assistance programs.
            </p>
          </div>
          <div class="rounded-2xl border border-slate-200 p-6 dark:border-slate-800">
            <div class="text-sm font-bold text-slate-900 dark:text-slate-100">2) Prepare documents</div>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
              Identity and eligibility proof are commonly required. Correct documents prevent delays.
            </p>
          </div>
          <div class="rounded-2xl border border-slate-200 p-6 dark:border-slate-800">
            <div class="text-sm font-bold text-slate-900 dark:text-slate-100">3) Apply safely</div>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
              Apply through recognized providers and avoid “guaranteed phone” claims with no verification.
            </p>
          </div>
        </div>
      </section>

      <!-- Eligibility -->
      <section id="eligibility" class="mt-12 scroll-mt-24">
        <div class="rounded-2xl border border-slate-200 p-6 dark:border-slate-800 md:p-10">
          <h2 class="text-2xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100">
            Who may qualify
          </h2>
          <p class="mt-3 max-w-3xl text-slate-600 dark:text-slate-300">
            Eligibility is typically based on household income or qualifying program participation. Requirements vary by verification path.
          </p>

          <div class="mt-6 grid gap-6 md:grid-cols-2">
            <div class="rounded-2xl border border-slate-200 p-6 dark:border-slate-800">
              <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100">Common eligibility paths</h3>
              <ul class="mt-4 space-y-2 text-sm text-slate-700 dark:text-slate-200">
                <li class="flex gap-2">
                  <span class="mt-0.5 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                  Income-based qualification (household income threshold)
                </li>
                <li class="flex gap-2">
                  <span class="mt-0.5 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                  Program-based qualification (participation proof)
                </li>
                <li class="flex gap-2">
                  <span class="mt-0.5 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                  Tribal-specific enhancements may exist in eligible areas
                </li>
              </ul>
            </div>

            <div class="rounded-2xl border border-slate-200 p-6 dark:border-slate-800">
              <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100">Documents to prepare</h3>
              <ul class="mt-4 space-y-2 text-sm text-slate-700 dark:text-slate-200">
                <li class="flex gap-2">
                  <span class="mt-0.5 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                  Government-issued ID (name and date of birth match)
                </li>
                <li class="flex gap-2">
                  <span class="mt-0.5 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                  Proof of eligibility (income documents or program participation)
                </li>
                <li class="flex gap-2">
                  <span class="mt-0.5 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                  Proof of address (if required by your verification path)
                </li>
              </ul>
            </div>
          </div>

          <div class="mt-6 rounded-2xl border border-slate-200 bg-slate-50 p-6 dark:border-slate-800 dark:bg-slate-900/40">
            <p class="text-sm text-slate-700 dark:text-slate-200">
              Note: This site provides informational guidance. Approval and device availability depend on verification rules and provider inventory.
            </p>
          </div>
        </div>
      </section>

      <!-- Providers -->
      <section class="mt-12">
        <h2 class="text-2xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100">
          Choosing a provider the smart way
        </h2>
        <p class="mt-3 max-w-3xl text-slate-600 dark:text-slate-300">
          Focus on network coverage, support quality, and clear terms. A good provider makes verification smoother and service reliable.
        </p>

        <div class="mt-6 grid gap-4 md:grid-cols-3">
          <div class="rounded-2xl border border-slate-200 p-6 dark:border-slate-800">
            <div class="text-sm font-bold text-slate-900 dark:text-slate-100">Coverage first</div>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
              Pick a provider that performs well where you live and work.
            </p>
          </div>
          <div class="rounded-2xl border border-slate-200 p-6 dark:border-slate-800">
            <div class="text-sm font-bold text-slate-900 dark:text-slate-100">Transparent terms</div>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
              Look for clear plan limits and straightforward enrollment steps.
            </p>
          </div>
          <div class="rounded-2xl border border-slate-200 p-6 dark:border-slate-800">
            <div class="text-sm font-bold text-slate-900 dark:text-slate-100">Real support</div>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
              Reliable help reduces failed verifications and delays.
            </p>
          </div>
        </div>

        <div class="mt-6">
          <a
            href="/posts/"
            class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:opacity-95 dark:bg-slate-100 dark:text-slate-900"
          >
            Browse provider and application guides
          </a>
        </div>
      </section>

      <!-- Scam safety -->
      <section class="mt-12">
        <div class="rounded-2xl border border-slate-200 p-6 dark:border-slate-800 md:p-10">
          <h2 class="text-2xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100">
            Scam alerts and safe-apply checklist
          </h2>
          <p class="mt-3 max-w-3xl text-slate-600 dark:text-slate-300">
            If a site promises guaranteed premium devices with no verification, treat it as a red flag. Use this checklist.
          </p>

          <div class="mt-6 grid gap-6 md:grid-cols-2">
            <div class="rounded-2xl border border-slate-200 p-6 dark:border-slate-800">
              <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100">Red flags</h3>
              <ul class="mt-4 space-y-2 text-sm text-slate-700 dark:text-slate-200">
                <li class="flex gap-2">
                  <span class="mt-0.5 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                  “Guaranteed iPhone” claims without eligibility checks
                </li>
                <li class="flex gap-2">
                  <span class="mt-0.5 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                  Requests for unusual upfront fees or unrelated payments
                </li>
                <li class="flex gap-2">
                  <span class="mt-0.5 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                  No clear company identity, address, or support channel
                </li>
              </ul>
            </div>

            <div class="rounded-2xl border border-slate-200 p-6 dark:border-slate-800">
              <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100">Safe steps</h3>
              <ul class="mt-4 space-y-2 text-sm text-slate-700 dark:text-slate-200">
                <li class="flex gap-2">
                  <span class="mt-0.5 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                  Use reputable provider application pages
                </li>
                <li class="flex gap-2">
                  <span class="mt-0.5 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                  Verify your personal details match your documents
                </li>
                <li class="flex gap-2">
                  <span class="mt-0.5 inline-block h-2 w-2 rounded-full bg-slate-900 dark:bg-slate-100"></span>
                  Keep screenshots and confirmation details for your records
                </li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section class="mt-12">
        <div class="rounded-2xl border border-slate-200 p-6 dark:border-slate-800 md:p-10">
          <h2 class="text-2xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100">
            Frequently asked questions
          </h2>

          <div class="mt-6 space-y-4">
            <details class="rounded-xl border border-slate-200 p-4 dark:border-slate-800">
              <summary class="cursor-pointer text-sm font-semibold text-slate-900 dark:text-slate-100">
                Can I choose a specific phone model?
              </summary>
              <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
                Usually no. Models depend on provider inventory and local availability. Some providers offer choices, but there is no universal guarantee.
              </p>
            </details>

            <details class="rounded-xl border border-slate-200 p-4 dark:border-slate-800">
              <summary class="cursor-pointer text-sm font-semibold text-slate-900 dark:text-slate-100">
                How long does approval take?
              </summary>
              <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
                Timing varies by verification path and document quality. Missing or mismatched information is the most common cause of delays.
              </p>
            </details>

            <details class="rounded-xl border border-slate-200 p-4 dark:border-slate-800">
              <summary class="cursor-pointer text-sm font-semibold text-slate-900 dark:text-slate-100">
                Is this the government website?
              </summary>
              <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
                No. This is an informational guide. For official enrollment rules and verification, follow official program pathways and provider processes.
              </p>
            </details>

            <details class="rounded-xl border border-slate-200 p-4 dark:border-slate-800">
              <summary class="cursor-pointer text-sm font-semibold text-slate-900 dark:text-slate-100">
                Do I need to recertify?
              </summary>
              <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
                Lifeline generally requires ongoing eligibility. Recertification rules and timing can depend on the verification path and provider notices.
              </p>
            </details>
          </div>
        </div>
      </section>

      <!-- Footer CTA -->
      <section class="mt-12">
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6 dark:border-slate-800 dark:bg-slate-900/40 md:p-10">
          <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
              <h2 class="text-xl font-extrabold text-slate-900 dark:text-slate-100">
                Ready to publish your first real guide?
              </h2>
              <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
                Add a markdown post in <span class="font-semibold">src/data/blog</span> and commit. Cloudflare will update your site automatically.
              </p>
            </div>
            <div class="flex gap-3">
              <a
                href="/posts/"
                class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:opacity-95 dark:bg-slate-100 dark:text-slate-900"
              >
                Go to Posts
              </a>
              <a
                href="/search/"
                class="inline-flex items-center justify-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-900"
              >
                Search
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
